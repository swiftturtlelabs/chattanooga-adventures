{
  "hosting": [
    {
      "target": "production",
      "public": ".",
      "ignore": [
        "firebase.json",
        ".firebaserc",
        ".github/**",
        ".gitignore",
        ".htaccess",
        "docs/**",
        "README.md"
      ],
      "cleanUrls": true,
      "trailingSlash": false,
      "headers": [
        {
          "source": "**/*.@(js|css|html)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "max-age=3600"
            }
          ]
        }
      ]
    },
    {
      "target": "test",
      "public": ".",
      "ignore": [
        "firebase.json",
        ".firebaserc",
        ".github/**",
        ".gitignore",
        ".htaccess",
        "docs/**",
        "README.md"
      ],
      "cleanUrls": true,
      "trailingSlash": false,
      "headers": [
        {
          "source": "**/*.@(js|css|html)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "max-age=3600"
            }
          ]
        }
      ]
    }
  ]
}
