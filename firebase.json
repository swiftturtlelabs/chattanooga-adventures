{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": [
    {
      "target": "production",
      "public": ".",
      "ignore": [
        "firebase.json",
        ".firebaserc",
        ".github/**",
        ".gitignore",
        ".cursor/**",
        "docs/**",
        "README.md",
        "QR_Codes/**",
        "scripts/**",
        "node_modules/**",
        "package.json",
        "package-lock.json",
        "tests/**",
        "coverage/**",
        "playwright-report/**",
        "test-results/**",
        "vitest.config.js",
        "playwright.config.js",
        "lighthouserc.json",
        ".eslintrc.json",
        ".prettierrc",
        ".husky/**",
        ".htmlvalidate.json",
        "firestore.rules"
      ],
      "cleanUrls": true,
      "trailingSlash": false,
      "headers": [
        {
          "source": "**/*.@(js|css|html)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "max-age=3600"
            }
          ]
        }
      ]
    },
    {
      "target": "test",
      "public": ".",
      "ignore": [
        "firebase.json",
        ".firebaserc",
        ".github/**",
        ".gitignore",
        ".cursor/**",
        "docs/**",
        "README.md",
        "QR_Codes/**",
        "scripts/**",
        "node_modules/**",
        "package.json",
        "package-lock.json",
        "tests/**",
        "coverage/**",
        "playwright-report/**",
        "test-results/**",
        "vitest.config.js",
        "playwright.config.js",
        "lighthouserc.json",
        ".eslintrc.json",
        ".prettierrc",
        ".husky/**",
        ".htmlvalidate.json",
        "firestore.rules"
      ],
      "cleanUrls": true,
      "trailingSlash": false,
      "headers": [
        {
          "source": "**/*.@(js|css|html)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "max-age=3600"
            }
          ]
        },
        {
          "source": "**",
          "headers": [
            {
              "key": "X-Robots-Tag",
              "value": "noindex, nofollow"
            }
          ]
        }
      ]
    }
  ]
}
