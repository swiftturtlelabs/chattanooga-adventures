{
  "ci": {
    "collect": {
      "url": [
        "https://chattanooga-adventures-test.web.app/",
        "https://chattanooga-adventures-test.web.app/support",
        "https://chattanooga-adventures-test.web.app/adventure?box=original&adventure=1"
      ],
      "numberOfRuns": 3
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.9 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["error", { "minScore": 0.9 }],
        "categories:seo": ["warn", { "minScore": 0.9 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
