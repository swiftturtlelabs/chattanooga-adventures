{
  "name": "chattanooga-adventures",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --check \"**/*.{js,css,html,json}\" --ignore-path .gitignore",
    "format:fix": "prettier --write \"**/*.{js,css,html,json}\" --ignore-path .gitignore",
    "validate:html": "html-validate \"*.html\"",
    "test": "vitest run tests/unit",
    "test:watch": "vitest tests/unit",
    "test:coverage": "vitest run --coverage",
    "test:api": "vitest run tests/api",
    "test:ui": "npx playwright test",
    "test:ui:update": "npx playwright test --update-snapshots",
    "test:all": "vitest run",
    "qr:general": "node scripts/generate-qr.js --general",
    "qr:adventure": "node scripts/generate-qr.js --adventure",
    "seed": "node scripts/seed-firestore.js",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json}": [
      "prettier --write"
    ],
    "*.html": [
      "prettier --write",
      "html-validate"
    ]
  },
  "browserslist": [
    "defaults",
    "not dead",
    "not op_mini all"
  ],
  "dependencies": {
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@firebase/rules-unit-testing": "^5.0.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-compat": "^6.2.0",
    "firebase-admin": "^13.6.1",
    "html-validate": "^10.8.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "serve": "^14.2.5",
    "vitest": "^4.0.18"
  }
}
